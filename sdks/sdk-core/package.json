{
  "name": "@ring-protocol/sdk-core",
  "version": "1.0.0",
  "description": "Shared TypeScript primitives for Ring SDK packages",
  "repository": "https://github.com/RingProtocol/ring-sdks.git",
  "keywords": [
    "ring-protocol",
    "ethereum"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "build": "../../node_modules/.bin/tsup src/index.ts --format cjs,esm --dts --sourcemap --clean --out-dir dist --external jsbi,big.js,decimal.js-light,toformat,@ethersproject/address,@ethersproject/bytes,@ethersproject/keccak256,@ethersproject/strings,tiny-invariant",
    "lint": "tsdx lint src",
    "release": "semantic-release",
    "start": "tsdx watch",
    "test": "tsdx test"
  },
  "dependencies": {
    "@ethersproject/address": "^5.0.2",
    "@ethersproject/bytes": "^5.7.0",
    "@ethersproject/keccak256": "5.7.0",
    "@ethersproject/strings": "5.7.0",
    "big.js": "^5.2.2",
    "decimal.js-light": "^2.5.0",
    "jsbi": "^3.1.4",
    "tiny-invariant": "^1.1.0",
    "toformat": "^2.0.0"
  },
  "devDependencies": {
    "@types/big.js": "^4.0.5",
    "@types/jest": "^24.0.25",
    "babel-eslint": "10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-config-react-app": "7.0.1",
    "eslint-plugin-flowtype": "8.0.3",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "^3.4.1",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "tsdx": "^0.14.1",
    "typescript": "^4.3.3"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "singleQuote": true
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "release": {
    "extends": "semantic-release-monorepo",
    "branches": [
      {
        "name": "main",
        "prerelease": false
      }
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "angular",
          "releaseRules": "../../publishing/release-rules.cjs"
        }
      ],
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "node ../../publishing/replace-workspace-deps.js",
          "successCmd": "git restore ../*/package.json ../../yarn.lock && rm -f ../../yarn.lock.bak && yarn --cwd ../..",
          "failCmd": "git restore ../*/package.json ../../yarn.lock && rm -f ../../yarn.lock.bak && yarn --cwd ../.."
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  }
}
